# Auto detect text files and normalize line endings to LF
* text=auto

# Frontend JavaScript files
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf

# Configuration
*.yml text eol=lf
*.yaml text eol=lf
*.env* text eol=lf

# Markdown
*.md text eol=lf

# Git ignore
.gitignore text eol=lf
.gitattributes text eol=lf

# Diff files
*.diff text eol=lf
*.patch text eol=lf
